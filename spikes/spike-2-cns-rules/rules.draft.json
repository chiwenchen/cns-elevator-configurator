    {
      "clause_id": "CNS-15827-20-5.2.5.7.1-a",
      "title": "車廂頂避險空間淨高 (站立姿勢, 牽引式/間接液壓)",
      "description": "車廂位於最高位置時，車廂頂站立姿勢避險空間淨高應 ≥ 2.00 m + 0.035v² (v = m/s)",
      "constraint_type": "custom_formula",
      "evaluate": "shaft.overhead_mm - model.car_height_mm >= 2000 + 0.035 * (model.rated_speed_mps ** 2) * 1000",
      "severity": "blocker",
      "applies_when": { "model.drive_type": ["traction", "indirect_hydraulic"] },
      "source": "CNS 15827-20 §5.2.5.7.1",
      "requires_verification": true
    },
    {
      "clause_id": "CNS-15827-20-5.2.5.7.1-b",
      "title": "車廂頂避險空間淨高 (正向驅動/直接液壓)",
      "description": "正向驅動及直接作用液壓電梯之車廂頂避險空間不必計算 0.035v² 跳衝值，站立姿勢 ≥ 2.00 m",
      "constraint_type": "custom_formula",
      "evaluate": "shaft.overhead_mm - model.car_height_mm >= 2000",
      "severity": "blocker",
      "applies_when": { "model.drive_type": ["direct_hydraulic", "positive"] },
      "source": "CNS 15827-20 §5.2.5.7.1",
      "requires_verification": true
    },
